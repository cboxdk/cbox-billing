{
  "name": "@cboxdk/cbox-billing",
  "version": "1.0.0",
  "description": "Typed TypeScript client for the Cbox Billing management + enforcement API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "example": "tsx examples/quickstart.ts"
  },
  "keywords": [
    "cbox",
    "billing",
    "metering",
    "subscriptions",
    "usage-based-billing",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cboxdk/cbox-billing.git",
    "directory": "sdks/typescript"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
