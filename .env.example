APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE defaults to database/database.sqlite; set an absolute path to override.
# DB_DATABASE=/absolute/path/to/database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# Cbox Billing engine — durable stores (also bound explicitly in BillingServiceProvider).
CBOX_BILLING_CURRENCY_LOCK_STORE=database
CBOX_BILLING_EVENT_LOG=database
CBOX_BILLING_RECONCILE_CHECKPOINT=database

# Payment settlement webhook (manual gateway). Deny-by-default: with no secret the
# verifier refuses every payload.
# CBOX_BILLING_WEBHOOK_SECRET=

# Hosted checkout + customer portal (ADR-0009). How long an opaque session token stays usable.
CBOX_BILLING_HOSTED_SESSION_TTL=30

# Stripe payment gateway (cboxdk/laravel-billing-stripe). When STRIPE_SECRET is set the
# Stripe gateway is bound as the PaymentGateway; otherwise the manual gateway is the
# fallback. STRIPE_PUBLISHABLE is safe to expose to the browser (the payment element);
# STRIPE_WEBHOOK_SECRET verifies inbound Stripe webhooks. Never commit real keys.
# STRIPE_SECRET=
# STRIPE_PUBLISHABLE=
# STRIPE_WEBHOOK_SECRET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- On-prem licensing (issuer keys) ---
# The base64 Ed25519 PRIVATE key that signs licenses + revocation lists. This is a
# SECRET: never commit it, never log it. Generate a pair with
# `php artisan billing:license-keygen` and paste the private key here (this file's
# real .env is gitignored). Leave empty to run without licensing enabled.
CBOX_LICENSE_SIGNING_KEY=
# The matching base64 Ed25519 PUBLIC key — safe to share; bundle it in the
# self-hosted cbox-id deployment so it can verify licenses offline.
CBOX_LICENSE_PUBLIC_KEY=
# Optional issuer knobs (sensible defaults applied when unset).
CBOX_LICENSE_VALIDITY_DAYS=365
CBOX_LICENSE_GRACE_DAYS=14
CBOX_LICENSE_CLOCK_SKEW=60
