APP_NAME="Cbox Billing"
# This template teaches PRODUCTION-safe defaults. For local development, copy it to
# `.env`, then set APP_ENV=local, APP_DEBUG=true, and DB_CONNECTION=sqlite (see below).
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://billing.example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Structured logging. In a containerised production deployment set LOG_CHANNEL=json for
# one-line JSON records on stdout (a collector ingests them without a parser). The `stack`
# default writes human-readable files; `stderr` is the plain-text container option.
LOG_CHANNEL=json
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Production runs on a real RDBMS. Point DB_CONNECTION at pgsql (recommended) or mysql and
# fill in the connection. The migrations use portable column types (json(), standard
# integers/strings) and run on Postgres, MySQL and SQLite alike.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cbox_billing
DB_USERNAME=cbox_billing
DB_PASSWORD=
# MySQL: DB_CONNECTION=mysql, DB_PORT=3306.
# Local-only: DB_CONNECTION=sqlite (zero-config; DB_DATABASE defaults to
# database/database.sqlite). Do not run SQLite in production.
# DB_DATABASE=/absolute/path/to/database/database.sqlite

# Cbox Billing engine — durable stores (also bound explicitly in BillingServiceProvider).
CBOX_BILLING_CURRENCY_LOCK_STORE=database
CBOX_BILLING_EVENT_LOG=database
CBOX_BILLING_RECONCILE_CHECKPOINT=database

# Payment settlement webhook (manual gateway). Deny-by-default: with no secret the
# verifier refuses every payload.
# CBOX_BILLING_WEBHOOK_SECRET=

# Hosted checkout + customer portal (ADR-0009). How long an opaque session token stays usable.
CBOX_BILLING_HOSTED_SESSION_TTL=30

# Embeddable storefront (#57): pricing tables + paywall. The default CTA hand-off target a
# pricing table uses when it sets no cta_url_template of its own — your checkout / signup entry,
# which receives the chosen plan+currency+interval and mints the org-scoped hosted checkout.
# Unset falls back to the app-root path (relative), so a table with no target stays self-contained.
# CBOX_BILLING_STOREFRONT_CHECKOUT_URL=
# The public origin the embed snippets point back at (defaults to APP_URL). Override only when the
# marketing embed must load the table from a different public hostname than the app runs on.
# CBOX_BILLING_STOREFRONT_EMBED_BASE_URL=

# Seats. Purchased Full seats (the subscription quantity) drive billing; assignment is
# explicit and app-side. Auto-assign gives a FREE purchased seat to a management-role member
# on join when one is free (never auto-buys). Default off — assignment is manual.
CBOX_BILLING_SEAT_AUTO_ASSIGN=false

# Stripe payment gateway (cboxdk/laravel-billing-stripe). When STRIPE_SECRET is set the
# Stripe gateway is bound as the PaymentGateway; otherwise the manual gateway is the
# fallback. STRIPE_PUBLISHABLE is safe to expose to the browser (the payment element);
# STRIPE_WEBHOOK_SECRET verifies inbound Stripe webhooks. Never commit real keys.
# STRIPE_SECRET=
# STRIPE_PUBLISHABLE=
# STRIPE_WEBHOOK_SECRET=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Transactional email. The lifecycle notifications (invoice issued, receipt, dunning,
# renewal reminder, subscription changed, license delivery) are queued and sent through
# this mailer. Point MAIL_MAILER at a real transport (smtp / ses / postmark / resend) in
# production; `log` writes them to the log instead of delivering.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="billing@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Cbox ID (identity provider + federated RBAC) ---
# The Cbox ID instance this app signs in against AND declares its roles/permissions to.
# The SDK discovers every endpoint from {issuer}/.well-known/openid-configuration.
CBOX_ID_ISSUER=
CBOX_ID_CLIENT_ID=
CBOX_ID_CLIENT_SECRET=
CBOX_ID_REDIRECT_URI=
# Federated RBAC: `php artisan cbox-id:publish-manifest` (run on deploy) pushes the
# roles + permissions declared in config/cbox-id-client.php to Cbox ID. The billing
# OAuth client must hold the `apps.manifest` scope (Cbox ID console → Developers → Apps).
#
# Provisioning webhooks (member/role/directory/org events). The shared signing secret the
# SDK verifies the X-Cbox-Signature HMAC against. Deny-by-default: with NO secret set, the
# receiver at POST /webhooks/cbox-id fails closed and refuses every payload. Copy the
# signing secret from the Cbox ID console (Developers → Webhooks).
CBOX_ID_WEBHOOK_SECRET=
# CBOX_ID_WEBHOOK_TOLERANCE=300
# Off-thread processing of the verified events (defaults to the app queue/connection).
# CBOX_ID_WEBHOOK_QUEUE_CONNECTION=
# CBOX_ID_WEBHOOK_QUEUE=
#
# Provider-console operator allowlist (config/billing.php → 'console'). THE coarse authorization
# boundary (SEC-1): a valid Cbox ID sign-in is NOT enough to reach the console — Cbox ID is a
# live, multi-tenant issuer that also holds customer/end-user accounts. Only a session whose
# identity belongs to one of these operator organizations (your internal `cbox` operator tenant)
# may operate the console. Comma-separated Cbox ID org id(s).
#
# DENY-BY-DEFAULT / FAIL-CLOSED: leave BOTH lists empty and the console denies EVERY session and
# logs an actionable warning. Set your real operator org id here in production. This is coarser
# than and independent of CBOX_ID_RBAC_ENFORCE below (which refines access WITHIN the operator
# org once Cbox ID emits `permissions`). See docs/identity/console-access.md.
#   • Live deploy: set to your Cbox ID operator organization id, e.g. CBOX_BILLING_OPERATOR_ORGS=org_01cbox...
#   • Local/demo mode (no CBOX_ID_ISSUER): the demo sign-in's org is `01demo0org0systems`, so set
#     CBOX_BILLING_OPERATOR_ORGS=01demo0org0systems to reach the console locally.
CBOX_BILLING_OPERATOR_ORGS=
# Optional break-glass: individually allowlisted Cbox ID subject(s) (comma-separated `sub`s),
# admitted regardless of org. Leave empty unless you need a specific out-of-org operator.
CBOX_BILLING_OPERATOR_SUBJECTS=
#
# RBAC enforcement (config/billing.php → 'rbac'). The `billing.permission:<feature:action>`
# middleware is INERT while false: it resolves the caller's permissions onto the request but
# never blocks. Flip to true ONLY once Cbox ID emits a `permissions` claim AND you intend
# strict deny-by-default on the console — a caller without the required slug then gets 403.
# This is the FINE layer beneath the always-on operator-org gate above.
CBOX_ID_RBAC_ENFORCE=false
#
# Per-environment tenancy. Cbox ID is environment-scoped; until it emits an `environment`
# claim, every billing org groups under this single home-environment key so a single-plane
# deploy Just Works. See docs/identity/tenancy.md.
CBOX_ID_ENVIRONMENT_DEFAULT=default

# --- On-prem licensing (issuer keys) ---
# The base64 Ed25519 PRIVATE key that signs licenses + revocation lists. This is a
# SECRET: never commit it, never log it. Generate a pair with
# `php artisan billing:license-keygen` and paste the private key here (this file's
# real .env is gitignored). Leave empty to run without licensing enabled.
CBOX_LICENSE_SIGNING_KEY=
# The matching base64 Ed25519 PUBLIC key — safe to share; bundle it in the
# self-hosted cbox-id deployment so it can verify licenses offline.
CBOX_LICENSE_PUBLIC_KEY=
# Optional issuer knobs (sensible defaults applied when unset).
CBOX_LICENSE_VALIDITY_DAYS=365
CBOX_LICENSE_GRACE_DAYS=14
CBOX_LICENSE_CLOCK_SKEW=60

# --- Consume-license (this deployment's OWN plugins) ---
# The license THIS deployment installs to unlock its bundled commercial plugins — distinct
# from the issuer keys above. Empty = deny-by-default (free tier, nothing unlocks). Never
# commit a real key. Pairs with a stable deployment id the license is bound to.
CBOX_BILLING_LICENSE_KEY=
CBOX_BILLING_DEPLOYMENT_ID=

# --- CORS (config/cors.php) ---
# Deny-by-default: a comma-separated allow-list of exact browser origins permitted to call
# the API + hosted pages cross-origin. Empty = no cross-origin browser access (the
# server-to-server SDK uses a bearer token and is not subject to CORS).
CORS_ALLOWED_ORIGINS=
# CORS_ALLOWED_ORIGINS_PATTERNS=
# CORS_SUPPORTS_CREDENTIALS=false

# --- API rate limiting (config/billing.php → 'rate_limits') ---
# Per-token limits (requests/minute). The enforcement hot path (reserve/commit/usage) runs
# hotter than the management surface (subscriptions/payment-intents/licenses); the webhook
# has its own ceiling. Tune to your traffic.
CBOX_BILLING_THROTTLE_ENFORCEMENT=600
CBOX_BILLING_THROTTLE_MANAGEMENT=60
CBOX_BILLING_THROTTLE_WEBHOOK=120

# --- Observability: health endpoint (cboxdk/laravel-health, config/health.php) ---
# The health probes live under /health (liveness /health, readiness /health/ready with
# DB + cache + queue + storage checks). Liveness & readiness are public; the detail
# endpoints (/health/status, /health/metrics, /health/metrics/json) are gated by this token.
HEALTH_ENABLED=true
HEALTH_TOKEN=
# HEALTH_ALLOWED_IPS=10.0.0.0/8
# HEALTH_PUBLIC_ENDPOINTS=liveness,readiness

# --- Observability: telemetry (cboxdk/laravel-telemetry, config/telemetry.php) ---
# Collector-free metrics/traces/events with queue + HTTP + cache instrumentation. Off by
# default; enable in production and give it a metric store (redis recommended, or apcu).
# When enabled, scrape /telemetry metrics and/or point LOG_CHANNEL/stack at the `telemetry`
# log channel for structured logs.
TELEMETRY_ENABLED=false
# TELEMETRY_STORE=redis
# TELEMETRY_REDIS_CONNECTION=default
